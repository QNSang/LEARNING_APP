# App runtime
APP_NAME=AI Learning OS
ENVIRONMENT=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:3000

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# Gemini / LLM
GEMINI_API_KEY=
EXTRACTION_MODEL=gemini-2.5-flash-lite

# Document processing
UPLOAD_DIR=uploads
CHUNK_SIZE_CHARS=3200
CHUNK_OVERLAP_CHARS=400

# Async pipeline
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Local embeddings / future retrieval
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Optional provider fallback (not wired in current code yet)
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional Neo4j runtime
USE_NEO4J=false
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=
